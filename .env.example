# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# YouTube Data API v3 key (free). Create at:
#   https://console.cloud.google.com/  ->  enable "YouTube Data API v3"  ->  Credentials -> API key
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# Anthropic / Claude API key (free starter credits cover this PoC).
#   https://console.anthropic.com/  ->  Settings -> API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
